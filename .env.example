# Database Configuration
# Replace with your connection string (e.g. Postgres, SQLite)
DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/database_name

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_here
JWT_ALGORITHM=HS256

# Redis Configuration (Used for token blacklisting/caching)
REDIS_HOST=localhost
REDIS_PORT=6379
